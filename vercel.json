{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOW-FROM https://melvz.com" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'self' https://melvz.com http://localhost:*" }
      ]
    }
  ]
}
